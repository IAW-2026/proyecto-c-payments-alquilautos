// Configuración básica para conectar con PostgreSQL y generar el cliente
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Modelo de Pago (Etapa 2)
model Pago {
  id                String      @id @default(uuid())
  idReserva        String      // ID que viene de la Buyer App
  monto             Float
  estado            EstadoPago  @default(PENDIENTE)
  metodoPago        String?     // Ej: "Mercado Pago"
  externalPaymentId String?     // ID que nos da Mercado Pago
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  historial         HistorialEstado[]
}

// Para llevar el registro de qué pasó con cada pago
model HistorialEstado {
  id        String     @id @default(uuid())
  pagoId    String
  pago      Pago       @relation(fields: [pagoId], references: [id])
  estado    EstadoPago
  fecha     DateTime   @default(now())
  detalle   String?    // Ej: "Pago aprobado por el usuario"
}

enum EstadoPago {
  PENDIENTE
  APROBADO
  RECHAZADO
  CANCELADO
}